<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Title -->
    <mxCell id="t" value="&lt;b&gt;sy-last 完整流程&lt;/b&gt;" style="text;html=1;fontSize=18;fontColor=#1565C0;align=center;verticalAlign=middle;strokeColor=none;" vertex="1" parent="1">
      <mxGeometry x="160" y="10" width="480" height="40" as="geometry"/>
    </mxCell>
    <!-- Step 1: User input -->
    <mxCell id="s1" value="用户输入：sy-last 临时使用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=13;fontColor=#0D47A1;" vertex="1" parent="1">
      <mxGeometry x="260" y="70" width="280" height="50" as="geometry"/>
    </mxCell>
    <!-- Arrow 1→2 -->
    <mxCell id="a1-2" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;fillColor=#1565C0;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="400" y="120" as="sourcePoint"/>
        <mxPoint x="400" y="155" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- Step 2: AI extracts last conversation -->
    <mxCell id="s2" value="AI 提取最后一次交互内容&lt;br&gt;保留原始格式（含图片/文件链接）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;fontColor=#BF360C;" vertex="1" parent="1">
      <mxGeometry x="230" y="160" width="340" height="55" as="geometry"/>
    </mxCell>
    <!-- Decision: content validation -->
    <mxCell id="d1" value="内容 &amp;lt; 30 字？" style="diamond=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF8F00;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="335" y="240" width="130" height="60" as="geometry"/>
    </mxCell>
    <!-- Arrow 2→d1 -->
    <mxCell id="a2-d" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="400" y="215" as="sourcePoint"/>
        <mxPoint x="400" y="240" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- Yes branch → rejected -->
    <mxCell id="d1-y" value="是" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#C62828;" edge="1" parent="1" connectable="0">
      <mxGeometry x="0.35" relative="1" as="geometry">
        <mxPoint x="465" y="270" as="offset"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="s2b" value="拒绝：内容过短，请提供完整内容&lt;br&gt;或使用 last/session 标记" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontColor=#B71C1C;" vertex="1" parent="1">
      <mxGeometry x="530" y="255" width="250" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="a-d1-y" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;strokeColor=#C62828;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="465" y="270" as="sourcePoint"/>
        <mxPoint x="530" y="270" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- No branch → continue -->
    <mxCell id="d1-n" value="否" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;fontColor=#2E7D32;" edge="1" parent="1" connectable="0">
      <mxGeometry x="0.65" relative="1" as="geometry">
        <mxPoint x="335" y="305" as="offset"/>
      </mxGeometry>
    </mxCell>
    <!-- Step 3: Preview -->
    <mxCell id="s3" value="调用 sy-save(content=真实内容, notebook=临时使用, confirmed=false)&lt;br&gt;&lt;br&gt;预览信息：&lt;br&gt;📓 笔记本：临时使用&amp;nbsp;&amp;nbsp;📝 标题：sy-list &amp;nbsp;&amp;nbsp;🏷️ 标签：AI、sy、list&lt;br&gt;─────────────&lt;br&gt;用户：sy-list&amp;nbsp;&amp;nbsp;助手：📚 笔记本列表...&lt;br&gt;─────────────&lt;br&gt;确认保存？(y/N)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#E65100;fontSize=11;fontColor=#4E342E;" vertex="1" parent="1">
      <mxGeometry x="130" y="330" width="540" height="140" as="geometry"/>
    </mxCell>
    <!-- Arrow d1→s3 -->
    <mxCell id="a-d-s3" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="400" y="300" as="sourcePoint"/>
        <mxPoint x="400" y="330" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- Decision 2: y/N -->
    <mxCell id="d2" value="用户确认？" style="diamond=1;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#FF8F00;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="335" y="495" width="130" height="60" as="geometry"/>
    </mxCell>
    <!-- Arrow s3→d2 -->
    <mxCell id="a-s3-d2" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="400" y="470" as="sourcePoint"/>
        <mxPoint x="400" y="495" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- y branch -->
    <mxCell id="d2-y" value="y" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#2E7D32;fontWeight=bold;" edge="1" parent="1" connectable="0">
      <mxGeometry x="0.3" relative="1" as="geometry">
        <mxPoint x="465" y="525" as="offset"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="s4" value="调用 sy-save(confirmed=true)&lt;br&gt;POST /api/filetree/createDocWithMd" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontColor=#1B5E20;" vertex="1" parent="1">
      <mxGeometry x="530" y="510" width="250" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="a-d2-y" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="465" y="525" as="sourcePoint"/>
        <mxPoint x="530" y="525" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- Result -->
    <mxCell id="s5" value="✅ 已保存&lt;br&gt;📓 临时使用 / sy-list&lt;br&gt;🔗 siyuan://blocks/202606..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=12;fontColor=#4A148C;" vertex="1" parent="1">
      <mxGeometry x="545" y="600" width="230" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="a-s4-s5" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="655" y="560" as="sourcePoint"/>
        <mxPoint x="655" y="600" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <!-- N branch -->
    <mxCell id="d2-n" value="N" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#C62828;fontWeight=bold;" edge="1" parent="1" connectable="0">
      <mxGeometry x="0.7" relative="1" as="geometry">
        <mxPoint x="335" y="555" as="offset"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="s4b" value="取消保存，内容不写入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=12;fontColor=#B71C1C;" vertex="1" parent="1">
      <mxGeometry x="45" y="530" width="220" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="a-d2-n" value="" style="endArrow=classic;html=1;rounded=1;strokeWidth=2;strokeColor=#C62828;" edge="1" parent="1">
      <mxGeometry width="50" relative="1" as="geometry">
        <mxPoint x="335" y="540" as="sourcePoint"/>
        <mxPoint x="265" y="540" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
  </root>
</mxGraphModel>
